# Environment Variables (Copy to .env and fill in your values)

# API Configuration
SAAVN_API_URL=https://saavn.sumit.co/api

# App Configuration
APP_NAME=Mume
APP_VERSION=1.0.0

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_RECOMMENDATIONS=true
ENABLE_ANALYTICS=false

# Storage
STORAGE_ENCRYPTION=true

# Optional: Analytics
# SENTRY_DSN=
# AMPLITUDE_KEY=

# Optional: Notifications
# FCM_SERVER_KEY=
# APNS_CERTIFICATE=
